export fn getYoutubeVideos(videoUrl: string): array {
    if !isYoutubeUrl(videoUrl) {
        return[]
    }
    const outputPath = `./output/${time.nowMs()}.mp4`
    const cmd = `yt-dlp --cookies ./src/cookies.txt -f bestvideo[ext=mp4]+bestaudio[ext=m4a]/best --merge-output-format mp4 -o ${outputPath} ${videoUrl}`

    const result = process.shell(cmd, {
        stdout: true
    })

    if !result.success {
        io.println(result.stderr)
        return[]
    }

    const file = {
        type: "youtube",
        file: outputPath,
        source: videoUrl
    }
    return [file]
}
import std "json";
import std "process";
import std "io";
import std "time";
import std "fs";

fn isYoutubeUrl(videoUrl: string): bool {
    return videoUrl.includes("youtube.com/watch") or videoUrl.includes("youtu.be/") or videoUrl.includes("youtube.com/shorts")
}

